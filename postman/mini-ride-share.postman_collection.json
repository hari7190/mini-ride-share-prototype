          "raw": "{\n  \"pickupLocation\": \"{{pickupLocation}}\",\n  \"destination\": \"{{destination}}\"\n}"
        },
        "url": "{{baseUrl}}/api/rider/request",
        "description": "POST /api/rider/request — `RideRequestDTO`; uses `pickupLocation` and `destination` (longitude,latitude)."
