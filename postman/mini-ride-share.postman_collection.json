{
  "info": {
    "_postman_id": "c4e8b2a1-7d3f-4e9c-a1b2-9f8e7d6c5b4a",
    "name": "Mini Ride Share — Register & Request Ride",
    "description": "Runs in order: register rider + two drivers; each driver logs in and PATCHes location; rider logs in and requests a ride.\n\n**Collection variables:** set `baseUrl` to your gateway or ingress root (same host must route `/api/auth`, `/api/rider`, `/api/locationtracker`).\n\nCoordinates are `longitude,latitude` (optional spaces after commas are fine).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost"
    },
    {
      "key": "riderUsername",
      "value": "rider_demo"
    },
    {
      "key": "driver1Username",
      "value": "driver_demo"
    },
    {
      "key": "driver2Username",
      "value": "driver2_demo"
    },
    {
      "key": "pickupLocation",
      "value": "-79.69575952135341,43.612025891341005"
    },
    {
      "key": "destination",
      "value": "-79.6082489304893,43.686569358823284"
    },
    {
      "key": "driver1Location",
      "value": "-79.7010154843996,43.60728189925817"
    },
    {
      "key": "driver2Location",
      "value": "-79.70891104676,43.600305555418224"
    },
    {
      "key": "password",
      "value": "ChangeMe123!"
    }
  ],
  "item": [
    {
      "name": "1. Register Rider",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{riderUsername}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"RIDER\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register",
        "description": "POST /api/auth/register — creates user with role RIDER (auth-service)."
      },
      "response": []
    },
    {
      "name": "2. Register Driver 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{driver1Username}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"DRIVER\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register",
        "description": "POST /api/auth/register — creates user with role DRIVER (auth-service)."
      },
      "response": []
    },
    {
      "name": "3. Register Driver 2",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{driver2Username}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"DRIVER\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register",
        "description": "POST /api/auth/register — second DRIVER account."
      },
      "response": []
    },
    {
      "name": "4. Login as Driver 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "const body = pm.response.json();",
              "pm.test('Token present', function () {",
              "    pm.expect(body.token).to.be.a('string').and.not.empty;",
              "});",
              "pm.collectionVariables.set('driver1Token', body.token);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{driver1Username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login",
        "description": "Saves JWT to collection variable `driver1Token` for location update."
      },
      "response": []
    },
    {
      "name": "5. Location Update (Driver 1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{driver1Token}}",
              "type": "string"
            }
          ]
        },
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"currentLocation\": \"{{driver1Location}}\"\n}"
        },
        "url": "{{baseUrl}}/api/locationtracker/update",
        "description": "PATCH /api/locationtracker/update — uses `driver1Location` (longitude,latitude)."
      },
      "response": []
    },
    {
